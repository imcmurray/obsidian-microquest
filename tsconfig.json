{
	"compilerOptions": {
		"baseUrl": "src",
		"target": "ES6",
		"module": "ESNext",
		"moduleResolution": "node",
		"lib": ["DOM", "ES5", "ES6", "ES7"],
		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"inlineSourceMap": true,
		"inlineSources": true,

		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"]
}
